# Slack tokens — from api.slack.com/apps → your app
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Groq — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key

# Live job listings (optional) — RapidAPI key for JSearch.
# Get a free key: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Without it, search_jobs still returns curated board links + keywords.
JSEARCH_API_KEY=your_rapidapi_key
