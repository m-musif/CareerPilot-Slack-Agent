{
  "display_information": {
    "name": "CareerPilot",
    "description": "AI teammate for career roadmaps, research summaries, and resume tips.",
    "background_color": "#2c2d30"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "CareerPilot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/career",
        "description": "Career advice, resume tips, internship guidance",
        "usage_hint": "[your question]",
        "should_escape": false
      },
      {
        "command": "/research",
        "description": "Research summaries and technical explanations",
        "usage_hint": "[topic or paper]",
        "should_escape": false
      },
      {
        "command": "/resume",
        "description": "Resume and LinkedIn optimization tips",
        "usage_hint": "[paste bullet or section]",
        "should_escape": false
      },
      {
        "command": "/forget",
        "description": "Clear CareerPilot's memory of our conversation",
        "should_escape": false
      },
      {
        "command": "/help",
        "description": "Show CareerPilot commands and examples",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "chat:write",
        "commands",
        "im:history",
        "im:read",
        "im:write",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
